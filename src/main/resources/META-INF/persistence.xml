<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="ForecastProPU" transaction-type="JTA">
        <jta-data-source>jdbc/ForecastProDS</jta-data-source>
        <class>com.forecastpro.entity.User</class>
        <class>com.forecastpro.entity.Category</class>
        <class>com.forecastpro.entity.Product</class>
        <class>com.forecastpro.entity.Sale</class>
        <class>com.forecastpro.entity.Forecast</class>
        <class>com.forecastpro.entity.Message</class>
        <class>com.forecastpro.entity.Vendor</class>
        <class>com.forecastpro.entity.InventoryMovement</class>
        <class>com.forecastpro.entity.StockRequest</class>
        <!-- Schema is managed in MySQL; EclipseLink must not alter tables at deploy. -->
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            <property name="eclipselink.target-database" value="org.eclipse.persistence.platform.database.MySQLPlatform"/>
            <property name="eclipselink.ddl-generation" value="none"/>
            <property name="eclipselink.ddl-generation.output-mode" value="none"/>
            <property name="eclipselink.logging.level" value="INFO"/>
        </properties>
    </persistence-unit>
</persistence>
