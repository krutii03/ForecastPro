@startuml sequence-login
!theme plain
skinparam shadowing false

title ForecastPro — Login Sequence Diagram

actor User
participant "LoginBean" as LB
participant "AuthService" as AS
participant "UserRepository" as UR
participant "PasswordUtil" as PU
database "MySQL" as DB
participant "UserSessionBean" as US

User -> LB : enter username / password\nclick Login
LB -> AS : authenticate(username, password)
AS -> UR : findByUsername(username)
UR -> DB : SELECT * FROM users WHERE username = ?
DB --> UR : user row
UR --> AS : Optional<User>

alt user not found or disabled
  AS --> LB : BusinessException
  LB --> User : show error message
else valid user
  AS -> PU : matches(plain, hashed)
  PU --> AS : true/false
  alt password invalid
    AS --> LB : BusinessException
    LB --> User : show error message
  else password valid
    AS --> LB : User entity
    LB -> US : setCurrentUser(user)
    alt role = VENDOR
      LB --> User : redirect /vendor/dashboard.xhtml
    else other roles
      LB --> User : redirect /app/dashboard.xhtml
    end
  end
end

@enduml
