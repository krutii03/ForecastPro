@startuml activity-message
!theme plain
skinparam shadowing false

title ForecastPro — Messaging Activity Diagram

start

:Open Messages page (MessageBean);

if (Sender role?) then (Employee / Vendor)
  :Compose subject and message;
  :Send to Admin (MessageBean.sendToAdmin);
  :MessageService.sendToAdmin() → first admin user;
elseif (Admin / Sales Manager) then
  :Select recipient user;
  :Compose subject and message;
  :Send direct (MessageBean.sendDirect);
  :MessageService.sendMessage();
else (other)
endif

:Validate subject and body;
:Create Message entity (status = OPEN);
:MessageRepository.save(message);
:Refresh inbox (listMessages / findForUser);

:Receiver opens Messages page;
:View sent and received messages;

if (Close message?) then (yes)
  :MessageService.closeMessage();
  :Status = CLOSED;
endif

stop

@enduml
