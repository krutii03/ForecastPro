@startuml activity-stock-request
!theme plain
skinparam shadowing false

title ForecastPro — Stock Request Workflow Activity Diagram

start

partition "Admin / Sales Manager" {
  :Open Stock Requests (StockRequestBean);
  :Select product, vendor, quantity;
  :Submit request;
  :StockRequestService.create();
  :Status = PENDING;
}

partition "Vendor Portal" {
  :Vendor views request (VendorRequestsBean);
  :Accept request;
  :Status = APPROVED;
  :Mark Ready & Packed;
  :Status = READY_PACKED;
  :Mark Out for Delivery;
  :Status = OUT_FOR_DELIVERY;
  :Mark Delivered;
  :Status = DELIVERED;
}

partition "Admin" {
  :Click Add to Stock;
  :StockRequestService.addToInventory();
  :Increase product.stockQuantity;
  :Create InventoryMovement\n(source: Vendor Delivery);
  :Status = COMPLETED;
}

stop

@enduml
