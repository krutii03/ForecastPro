@startuml manager-usecase
!theme plain
skinparam shadowing false
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #1E3A5F
  FontColor #1F2933
}
skinparam actor {
  BackgroundColor #E8F0FE
  BorderColor #1E3A5F
}

left to right direction

actor "Sales Manager" as Manager

rectangle "ForecastPro" {
  usecase "Login" as UC_Login
  usecase "Manage Products" as UC_ManageProducts
  usecase "Generate Demand Forecast" as UC_DemandForecast
  usecase "Generate Sales Forecast" as UC_SalesForecast
  usecase "View Analytics" as UC_ViewAnalytics
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Create Stock Requests" as UC_CreateStockRequests
  usecase "Generate Reports" as UC_GenerateReports
  usecase "Export PDF" as UC_ExportPdf
  usecase "Export Excel" as UC_ExportExcel
  usecase "Send Messages" as UC_SendMessages
  usecase "Logout" as UC_Logout
}

Manager --> UC_Login
Manager --> UC_ManageProducts
Manager --> UC_DemandForecast
Manager --> UC_SalesForecast
Manager --> UC_ViewAnalytics
Manager --> UC_ManageInventory
Manager --> UC_CreateStockRequests
Manager --> UC_GenerateReports
Manager --> UC_ExportPdf
Manager --> UC_ExportExcel
Manager --> UC_SendMessages
Manager --> UC_Logout

UC_GenerateReports ..> UC_ExportPdf : <<include>>
UC_GenerateReports ..> UC_ExportExcel : <<include>>

@enduml
