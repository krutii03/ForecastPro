@startuml vendor-usecase
!theme plain
skinparam shadowing false
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #1E3A5F
  FontColor #1F2933
}
skinparam actor {
  BackgroundColor #E8F0FE
  BorderColor #1E3A5F
}

left to right direction

actor "Vendor" as Vendor

rectangle "ForecastPro" {
  usecase "Login" as UC_Login
  usecase "View Dashboard" as UC_ViewDashboard
  usecase "View Stock Requests" as UC_ViewStockRequests
  usecase "Approve Requests" as UC_ApproveRequests
  usecase "Update Delivery Status" as UC_UpdateDeliveryStatus
  usecase "Send Messages" as UC_SendMessages
  usecase "Logout" as UC_Logout
}

Vendor --> UC_Login
Vendor --> UC_ViewDashboard
Vendor --> UC_ViewStockRequests
Vendor --> UC_ApproveRequests
Vendor --> UC_UpdateDeliveryStatus
Vendor --> UC_SendMessages
Vendor --> UC_Logout

UC_ApproveRequests ..> UC_ViewStockRequests : <<include>>
UC_UpdateDeliveryStatus ..> UC_ViewStockRequests : <<include>>

@enduml
