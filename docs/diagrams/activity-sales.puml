@startuml activity-sales
!theme plain
skinparam shadowing false

title ForecastPro — Sales Entry Activity Diagram

start

:Open Sales Entry page (SaleBean);
:Load categories (CategoryService.findAllForUi);
:Select category;
:Load products for category (ProductService.listByCategory);
:Select product;
:Enter quantity sold;
:Select sale date (maxDate = today);

:Click Save sale (SaleBean.recordSale);

:SaleService.recordSale(role, productId, qty, date);

if (Sale date in future?) then (yes)
  :Show error: date cannot be in future;
  stop
endif

if (Stock sufficient?) then (yes)
  :Create Sale entity;
  :SaleRepository.save(sale);
  :Decrement product.stockQuantity;
  :ProductRepository.save(product);
  :Show success message;
  :Reset quantity and date;
else (no)
  :Show error: insufficient stock;
  stop
endif

stop

@enduml
