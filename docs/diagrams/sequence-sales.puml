@startuml sequence-sales
!theme plain
skinparam shadowing false

title ForecastPro — Record Sale Sequence Diagram

actor User
participant "SaleBean" as SB
participant "SaleService" as SS
participant "SecurityService" as SEC
participant "ProductRepository" as PR
participant "SaleRepository" as SR
database "MySQL" as DB

User -> SB : select product, qty, date\nclick Save sale
SB -> SS : recordSale(role, productId, qty, saleDate)
SS -> SEC : requireAdminOrEmployee(role)
SEC --> SS : ok
SS -> SS : validate saleDate <= today

SS -> PR : findById(productId)
PR -> DB : SELECT product
DB --> PR : product row
PR --> SS : Product

alt insufficient stock
  SS --> SB : BusinessException
  SB --> User : show error
else stock ok
  SS -> SS : create Sale entity
  SS -> SR : save(sale)
  SR -> DB : INSERT INTO sales
  DB --> SR : ok
  SS -> PR : save(product)\nstockQuantity -= qty
  PR -> DB : UPDATE products SET stock_quantity
  DB --> PR : ok
  SS --> SB : Sale
  SB --> User : show success message
end

@enduml
