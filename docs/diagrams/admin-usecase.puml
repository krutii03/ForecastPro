@startuml admin-usecase
!theme plain
skinparam shadowing false
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #1E3A5F
  FontColor #1F2933
}
skinparam actor {
  BackgroundColor #E8F0FE
  BorderColor #1E3A5F
}

left to right direction

actor "Admin" as Admin

rectangle "ForecastPro" {
  usecase "Login" as UC_Login
  usecase "Manage Users" as UC_ManageUsers
  usecase "Manage Categories" as UC_ManageCategories
  usecase "Manage Products" as UC_ManageProducts
  usecase "Manage Sales" as UC_ManageSales
  usecase "Generate Demand Forecast" as UC_DemandForecast
  usecase "Generate Sales Forecast" as UC_SalesForecast
  usecase "View Analytics" as UC_ViewAnalytics
  usecase "Manage Inventory" as UC_ManageInventory
  usecase "Manage Vendors" as UC_ManageVendors
  usecase "Create Stock Requests" as UC_CreateStockRequests
  usecase "Generate Reports" as UC_GenerateReports
  usecase "Export PDF" as UC_ExportPdf
  usecase "Export Excel" as UC_ExportExcel
  usecase "Send Messages" as UC_SendMessages
  usecase "Logout" as UC_Logout
}

Admin --> UC_Login
Admin --> UC_ManageUsers
Admin --> UC_ManageCategories
Admin --> UC_ManageProducts
Admin --> UC_ManageSales
Admin --> UC_DemandForecast
Admin --> UC_SalesForecast
Admin --> UC_ViewAnalytics
Admin --> UC_ManageInventory
Admin --> UC_ManageVendors
Admin --> UC_CreateStockRequests
Admin --> UC_GenerateReports
Admin --> UC_ExportPdf
Admin --> UC_ExportExcel
Admin --> UC_SendMessages
Admin --> UC_Logout

UC_GenerateReports ..> UC_ExportPdf : <<include>>
UC_GenerateReports ..> UC_ExportExcel : <<include>>

@enduml
