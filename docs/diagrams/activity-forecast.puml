@startuml activity-forecast
!theme plain
skinparam shadowing false

title ForecastPro — Demand Forecast Generation Activity Diagram

start

:Open Demand Forecast page (DemandForecastBean);
:Select category and product;
:Click Generate;

:ForecastService.generateForecast(role, productId);

:Load monthly quantity series\n(SaleRepository.monthlyQuantityByProductNative);

if (Sales history exists?) then (yes)
  :Calculate 3-month Moving Average\n(MovingAverageForecaster.forecast);
  :Apply SimpleRegression on month index\n(Apache Commons Math);
  :Clamp regression to ±20% of MA;
  :Weighted ensemble:\n70% MA + 30% clamped regression;
  :predictedRevenue = predictedSales × price;
  :Calculate bounds: predicted ± σ\n(StandardDeviation);
  :Set forecastMonth = next calendar month;
  :Upsert Forecast (ForecastRepository.save);
  :Build line/bar charts (ChartModel);
  :Display KPIs and forecast history table;
  stop
else (no)
  :Show error: no sales history;
  stop
endif

@enduml
