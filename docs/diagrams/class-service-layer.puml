@startuml class-service-layer
!theme plain
skinparam shadowing false
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

title ForecastPro — Service Layer Architecture

package "Controllers (JSF @Named Beans)" #E8F0FE {
  class UserSessionBean
  class LoginBean {
    + login() : String
  }
  class UserManagementBean {
    + createUser()
    + saveEdit()
  }
  class CategoryBean {
    + create()
    + saveEdit()
    + delete()
  }
  class ProductBean {
    + save()
    + delete()
    + loadProducts()
  }
  class SaleBean {
    + recordSale()
    + loadProducts()
  }
  class DemandForecastBean {
    + generate()
    + loadRecentForecasts()
  }
  class SalesForecastBean {
    + generate()
    + loadRecentForecasts()
  }
  class AnalyticsBean {
    + refresh()
    + buildCharts()
  }
  class InventoryBean {
    + refresh()
  }
  class VendorBean {
    + save()
    + delete()
  }
  class StockRequestBean {
    + create()
    + addToStock()
    + updateStatus()
  }
  class VendorRequestsBean {
    + updateStatus()
  }
  class ReportsBean {
    + refresh()
    + applyFilters()
    + exportCurrentPdf()
    + exportCurrentExcel()
  }
  class MessageBean {
    + sendDirect()
    + sendToAdmin()
    + closeMessage()
  }
  class DashboardBean {
    + refresh()
  }
}

package "Services (@Stateless EJB)" #ECFDF5 {
  class AuthService {
    + authenticate(username, password) : User
  }
  class SecurityService {
    + requireAdmin()
    + requireAdminOrManager()
    + requireAdminOrEmployee()
    + requireAuthenticated()
  }
  class UserService
  class CategoryService {
    + create()
    + update()
    + delete()
    + listAll()
  }
  class ProductService {
    + save()
    + delete()
    + listByCategory()
  }
  class SaleService {
    + recordSale()
  }
  class ForecastService {
    + generateForecast()
    + computeNextMonthForecast()
    + computeDashboardKpis()
  }
  class AnalyticsService {
    + totalRevenue()
    + monthlySummary()
    + topSelling()
  }
  class AlertService {
    + inventoryAlerts()
    + inventoryRecommendations()
  }
  class InventoryService {
    + listHistory()
  }
  class VendorService {
    + save()
    + listForUi()
  }
  class StockRequestService {
    + create()
    + transitionStatus()
    + addToInventory()
  }
  class MessageService {
    + sendMessage()
    + listMessages()
    + closeMessage()
  }
  class SalesReportService {
    + monthlySales()
    + yearlyTotals()
  }
  class SeasonalityService {
    + seasonalityReport()
  }
  class DashboardService {
    + buildDashboard()
  }
}

package "Repositories (@Stateless EJB)" #FEF3C7 {
  class UserRepository
  class CategoryRepository
  class ProductRepository
  class SaleRepository
  class ForecastRepository
  class InventoryMovementRepository
  class VendorRepository
  class StockRequestRepository
  class MessageRepository
}

LoginBean --> AuthService
LoginBean --> UserSessionBean
UserManagementBean --> UserService
UserManagementBean --> SecurityService
CategoryBean --> CategoryService
ProductBean --> ProductService
SaleBean --> SaleService
SaleBean --> CategoryService
SaleBean --> ProductService
DemandForecastBean --> ForecastService
DemandForecastBean --> CategoryService
SalesForecastBean --> ForecastService
SalesForecastBean --> AnalyticsService
AnalyticsBean --> AnalyticsService
InventoryBean --> AlertService
InventoryBean --> InventoryService
VendorBean --> VendorService
StockRequestBean --> StockRequestService
StockRequestBean --> VendorService
VendorRequestsBean --> StockRequestService
ReportsBean --> SalesReportService
ReportsBean --> ForecastService
ReportsBean --> SeasonalityService
ReportsBean --> SaleRepository
ReportsBean --> ForecastRepository
ReportsBean --> InventoryMovementRepository
MessageBean --> MessageService
DashboardBean --> DashboardService

AuthService --> UserRepository
UserService --> UserRepository
CategoryService --> CategoryRepository
CategoryService --> SecurityService
ProductService --> ProductRepository
ProductService --> SecurityService
SaleService --> SaleRepository
SaleService --> ProductRepository
SaleService --> SecurityService
ForecastService --> ForecastRepository
ForecastService --> SaleRepository
ForecastService --> ProductRepository
AnalyticsService --> SaleRepository
AnalyticsService --> ForecastService
AlertService --> ProductRepository
AlertService --> ForecastRepository
InventoryService --> InventoryMovementRepository
VendorService --> VendorRepository
StockRequestService --> StockRequestRepository
StockRequestService --> ProductRepository
StockRequestService --> VendorRepository
StockRequestService --> InventoryMovementRepository
MessageService --> MessageRepository
MessageService --> UserRepository
SalesReportService --> SaleRepository
SeasonalityService --> SaleRepository
DashboardService --> SaleRepository
DashboardService --> ForecastRepository
DashboardService --> AlertService

@enduml
